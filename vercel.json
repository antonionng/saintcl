{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/email/lifecycle",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/email/weekly",
      "schedule": "0 9 * * 1"
    }
  ]
}
