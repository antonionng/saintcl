PORT=8080
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
OPENCLAW_DEFAULT_MODEL=anthropic/claude-sonnet-4
# Optional: exact browser origins for the hosted OpenClaw control UI.
# If omitted, startup falls back to Railway host-header origin mode until you set them.
# OPENCLAW_ALLOWED_ORIGINS=["https://your-service.up.railway.app","https://admin.yourdomain.com"]
